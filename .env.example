# --- Arc Testnet RPC ---
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network

# --- USDC on Arc Testnet ---
# Source: https://developers.circle.com/stablecoins/usdc-contract-addresses
USDC_CONTRACT_ADDRESS=0x3600000000000000000000000000000000000000

# --- Circle Programmable Wallets (REQUIRED) ---
# The agent uses Circle Programmable Wallets for all wallet operations.
# No raw private keys are needed.
# Get credentials at: https://console.circle.com
# Setup steps:
#   1. python agent/scripts/generate_entity_secret.py   → generates a secret
#   2. Paste the secret below as CIRCLE_ENTITY_SECRET
#   3. python agent/scripts/register_entity_secret.py   → registers with Circle
#   4. Create a wallet set in the Circle console → paste ID below
#
# Without these, the agent runs in SIMULATED mode (no real transactions).
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_SET_ID=

# USDC token ID on Arc testnet for Circle transfer API.
# Find yours at: https://developers.circle.com/w3s/reference/listtokens
CIRCLE_ARC_USDC_TOKEN_ID=

# --- DeFi Pool Addresses (optional -- enables live data feed) ---
# These pools use factory-deployed contracts; find your pool's address via
# the protocol's dApp or Arc testnet explorer: https://testnet.arcscan.app
# If left blank, the data feed falls back to clearly-labeled simulated data.
CURVE_POOL_ADDRESS=
XYLONET_POOL_ADDRESS=
DEFIONARC_POOL_ADDRESS=